# talond.yaml.example
# Copy to talond.yaml and edit for your environment.
# Canonical config shape validated by src/core/config/config-schema.ts
#
# All sections are optional — omitted sections use built-in defaults.
# Supports ${ENV_VAR} substitution (resolved at load time from process env).

# ---------------------------------------------------------------------------
# Storage — where talond persists all state (messages, threads, runs, etc.)
# ---------------------------------------------------------------------------
storage:
  type: sqlite                       # only "sqlite" supported for now
  path: data/talond.sqlite           # path to the SQLite database file

# ---------------------------------------------------------------------------
# Sandbox — container isolation for agent execution
# NOT YET IMPLEMENTED — agent runs on host for now. See TASK-037.
# These values are parsed and validated but have no effect until
# Docker sandbox support lands.
# ---------------------------------------------------------------------------
sandbox:
  runtime: docker                    # "docker" or "apple-container"
  image: talon-sandbox:latest        # container image for sandboxed runs
  maxConcurrent: 3                   # max simultaneous sandbox containers
  networkDefault: off                # "off" = no network in sandbox; "on" = allow
  idleTimeoutMs: 1800000             # kill idle container after 30 min
  hardTimeoutMs: 3600000             # hard kill after 60 min regardless of activity
  resourceLimits:
    memoryMb: 1024                   # memory cap per container (MB)
    cpus: 1                          # CPU core limit per container
    pidsLimit: 256                   # max processes per container

# ---------------------------------------------------------------------------
# Channels — inbound/outbound message adapters
# Working: telegram, slack, terminal
# Not yet implemented: discord (TASK-043), whatsapp (TASK-067)
# Not yet tested: email (TASK-049)
# ---------------------------------------------------------------------------
channels:
  - type: telegram                   # channel adapter type
    name: personal-telegram          # unique name (used in bindings + logs)
    enabled: true                    # set false to disable without removing
    config:
      token: ${TELEGRAM_BOT_TOKEN}   # bot token (from @BotFather)
      allowedUserIds:                # restrict to these Telegram user IDs
        - 123456789
      pollIntervalMs: 1000           # long-poll interval for updates (ms)

  - type: slack                      # Slack via Socket Mode (no public URL needed)
    name: work-slack
    enabled: true
    config:
      botToken: ${SLACK_BOT_TOKEN}   # Bot User OAuth Token (xoxb-...)
      appToken: ${SLACK_APP_TOKEN}   # App-Level Token for Socket Mode (xapp-...)
      signingSecret: ${SLACK_SIGNING_SECRET}  # signing secret from Slack app settings

# ---------------------------------------------------------------------------
# Personas — AI agent definitions, each with its own model + capabilities
# Personas are bound to channels via the bindings table (auto-created on startup).
# ---------------------------------------------------------------------------
personas:
  - name: assistant                  # unique persona identifier
    model: claude-sonnet-4-6         # AI model to use for this persona
    systemPromptFile: personas/assistant/system.md  # path to system prompt markdown
    skills: []                       # skill names to load (from skills/ directory)
    subagents:                       # sub-agent names (from subagents/default/)
      - session-summarizer
      - memory-groomer
      - memory-retriever
      - file-searcher
    capabilities:
      allow:                         # tools/actions this persona can use (default-deny)
        - channel.send:telegram      # format: domain.action:scope (* = wildcard)
        - fs.read:*
        - memory.access:*
        - subagent.invoke:*
        - subagent.background
      requireApproval:               # tools that need human confirmation before executing
        - fs.write:workspace         # NOT YET IMPLEMENTED — approval flow planned
    mounts:                          # host dirs to bind into sandbox containers
      - source: data/threads/{thread}/memory  # NOT YET ACTIVE — requires sandbox (TASK-037)
        target: /memory
        mode: ro                     # "ro" = read-only, "rw" = read-write
      - source: data/threads/{thread}/artifacts
        target: /artifacts
        mode: rw
    maxConcurrent: 2                 # max parallel agent runs for this persona

# ---------------------------------------------------------------------------
# IPC — file-based communication between talond daemon and talonctl CLI
# ---------------------------------------------------------------------------
ipc:
  pollIntervalMs: 500                # how often talonctl polls for responses (ms)
  daemonSocketDir: data/ipc/daemon   # directory for IPC command/response files

# ---------------------------------------------------------------------------
# Queue — durable message processing queue (SQLite-backed FIFO per thread)
# ---------------------------------------------------------------------------
queue:
  maxAttempts: 3                     # retry limit before sending to dead-letter
  backoffBaseMs: 1000                # initial retry delay (ms)
  backoffMaxMs: 60000                # max retry delay cap (ms, exponential backoff)
  concurrencyLimit: 5                # max messages processed in parallel

# ---------------------------------------------------------------------------
# Background workers — detached Claude Code jobs spawned by the foreground agent
# ---------------------------------------------------------------------------
backgroundAgent:
  enabled: true                      # master switch for background workers
  maxConcurrent: 3                   # max background Claude workers running at once
  defaultTimeoutMinutes: 30          # default wall-clock timeout per worker
  claudePath: claude                 # Claude Code CLI executable to launch

# ---------------------------------------------------------------------------
# Scheduler — cron/interval/one-shot task execution engine
# ---------------------------------------------------------------------------
scheduler:
  tickIntervalMs: 5000               # how often the scheduler checks for due tasks (ms)

# ---------------------------------------------------------------------------
# Auth — authentication for AI provider APIs
# ---------------------------------------------------------------------------
auth:
  mode: subscription                 # "subscription" = Claude Max (no API key needed)
  # mode: api_key                    # use "api_key" if paying per-token via API
  # apiKey: ${SUBAGENT_ANTHROPIC_API_KEY}  # main Anthropic API key (for api_key mode)
  providers:                         # per-provider credentials (used by sub-agents)
    anthropic:
      apiKey: ${SUBAGENT_ANTHROPIC_API_KEY}
    openai:
      apiKey: ${OPENAI_API_KEY}
      # baseURL: https://api.openai.com/v1  # override for proxies or compatible APIs
    # google:
    #   apiKey: ${GOOGLE_AI_API_KEY}        # Gemini API key (from ai.google.dev)
    # ollama:                               # local models — no API key needed
    #   baseURL: http://localhost:11434/v1   # Ollama server URL

# ---------------------------------------------------------------------------
# Context — rolling context window (auto-summarize + rotate long conversations)
# ---------------------------------------------------------------------------
context:
  thresholdTokens: 80000             # legacy fallback converted to default provider rotationThreshold
  recentMessageCount: 10             # recent messages included verbatim in new session

# ---------------------------------------------------------------------------
# Global settings
# ---------------------------------------------------------------------------
logLevel: info                       # trace | debug | info | warn | error | fatal
dataDir: data                        # root directory for all runtime data
