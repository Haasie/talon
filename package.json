{
  "name": "talon",
  "version": "0.1.0",
  "description": "Resilient, secure, extensible autonomous agent daemon",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "talonctl": "bin/talonctl.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && cp src/core/database/migrations/*.sql dist/core/database/migrations/",
    "dev": "tsx watch src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint \"src/**/*.ts\"",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "talond": "node dist/index.js",
    "talonctl": "node dist/cli/index.js",
    "migrate": "node dist/cli/index.js migrate"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.71",
    "@anthropic-ai/sdk": "^0.78.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "better-sqlite3": "^12.6.2",
    "commander": "^12.1.0",
    "cron-parser": "^4.9.0",
    "dockerode": "^4.0.2",
    "js-yaml": "^4.1.0",
    "marked": "^17.0.4",
    "marked-terminal": "^7.3.0",
    "neverthrow": "^8.0.0",
    "ora": "^9.3.0",
    "pino": "^9.3.2",
    "pino-pretty": "^11.2.2",
    "uuid": "^10.0.0",
    "write-file-atomic": "^6.0.0",
    "ws": "^8.19.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/dockerode": "^3.3.31",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.5.1",
    "@types/uuid": "^10.0.0",
    "@types/write-file-atomic": "^4.0.3",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^2.1.1",
    "eslint": "^9.9.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.3.3",
    "tsx": "^4.19.0",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8.3.0",
    "vitest": "^2.1.1"
  }
}
